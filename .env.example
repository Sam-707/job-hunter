# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=perplexity
LLM_API_KEY=pplx-...
LLM_BASE_URL=https://api.perplexity.ai
LLM_MODEL=sonar
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60

# Optional fallback for Anthropic compatibility
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./job_hunter.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/job_hunter

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# ── Extraction ────────────────────────────────────────────────────────────────
EXTRACTOR_TIMEOUT_SECONDS=15
EXTRACTOR_MAX_CONTENT_BYTES=500000
